# Vision AI Surveillance — Environment Variables
# Copy this file to .env and fill in your values
# NOTE: This app runs entirely in the browser — the API key is entered via the UI,
#       not loaded from this file. This file is for reference / future server-side use.

# Groq API Key (get yours free at https://console.groq.com)
# Format: gsk_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
GROQ_API_KEY=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

# Optional: Override the default vision model
# Options:
#   meta-llama/llama-4-scout-17b-16e-instruct   (default, fastest)
#   meta-llama/llama-4-maverick-17b-128e-instruct
#   llava-v1.5-7b-4096-preview
GROQ_MODEL=meta-llama/llama-4-scout-17b-16e-instruct

# Optional: Auto-analysis interval in milliseconds (default: 10000 = 10 seconds)
AUTO_ANALYZE_INTERVAL=10000

# Optional: JPEG capture quality 0.0-1.0 (default: 0.72)
CAPTURE_QUALITY=0.72

# Optional: Max capture width in pixels (default: 640)
CAPTURE_MAX_WIDTH=640
